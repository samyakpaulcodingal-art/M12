-- Setup: Create a sample customers table
CREATE TABLE customers (
    customer_id INT PRIMARY KEY,
    customer_name VARCHAR(50),
    city VARCHAR(50),
    grade INT
);

-- Insert sample data to test the operators
INSERT INTO customers (customer_id, customer_name, city, grade) VALUES
(1, 'John Doe', 'New York', 85),
(2, 'Jane Smith', 'Los Angeles', 120),
(3, 'Bob Johnson', 'New York', 150),
(4, 'Alice Brown', 'Chicago', 90);

---

-- Query 1: Customers who belong to New York OR have a grade above 100
SELECT * FROM customers 
WHERE city = 'New York' OR grade > 100;

-- Query 2: Customers who belong to New York AND have a grade value more than 100
SELECT * FROM customers 
WHERE city = 'New York' AND grade > 100;
