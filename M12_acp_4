(6, 'Books', 150, 'East');

---

-- The Core Assignment: Group, Filter aggregate results, and Sort
SELECT 
    product_category,
    SUM(amount) AS total_sales,
    COUNT(sale_id) AS total_orders
FROM sales
GROUP BY product_category           -- 1. GROUPING: Groups rows by category
HAVING SUM(amount) > 500            -- 2. FILTERING: Only keeps groups with total sales > 500
ORDER BY total_sales DESC;          -- 3. SORTING: Sorts categories from highest sales to lowest
